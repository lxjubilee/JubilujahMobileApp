{
  "expo": {
    "name": "Jubilujah",
    "slug": "jubilujah",
    "scheme": "jubilujah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Jubilujah-app-logo.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0F",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/Jubilujah-app-logo.png",
      "backgroundColor": "#0B0B0F",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jubilujah.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.jubilujah.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0F",
        "foregroundImage": "./assets/Jubilujah-app-logo.png"
      },
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.WAKE_LOCK"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-localization",
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "cdnBaseUrl": "https://cdn.jubileeverse.com",
      "apiBaseUrl": "https://api.jubileeverse.com/v1",
      "useMock": false,
      "dataSource": "manifest",
      "authBaseUrl": "https://api.jubileeinspire.com",
      "authMobileClientKey": "",
      "authSource": "jubilujah",
      "jiServiceClientId": "jubilujah",
      "jiServiceClientSecret": "",
      "turnstileSiteKey": "0x4AAAAAADJah9FpwSaEzlLP",
      "turnstileBaseUrl": "https://jubileeinspire.com",
      "accountBaseUrl": "https://api.jubilujah.com",
      "eas": {
        "projectId": "7354f6a2-75e4-4f29-9f07-7d5fda551d22"
      }
    },
    "owner": "gabeungureanu"
  }
}
